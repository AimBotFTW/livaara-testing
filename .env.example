# Supabase Configuration
# Required for database access and authentication
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Razorpay Configuration
# Required for processing payments and verifying webhooks
RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your_key_secret"
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"

# Admin & Notifications
# Required for sending transactional emails and defining admin access
ADMIN_EMAIL="admin@livaara.com"
RESEND_API_KEY="re_your_resend_api_key"
RESEND_FROM_EMAIL="onboarding@resend.dev"

# Analytics (Optional, but included for completeness)
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_CLARITY_ID="your_clarity_project_id"
